{
  "name": "Agent",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Display name of the agent"
    },
    "role_description": {
      "type": "string",
      "description": "Short description of the agent's role"
    },
    "system_prompt": {
      "type": "string",
      "description": "System prompt that defines the agent's behavior"
    },
    "model": {
      "type": "string",
      "enum": [
        "gpt-4o",
        "gpt-4o-mini",
        "gpt-4-turbo",
        "gpt-4",
        "gpt-3.5-turbo"
      ],
      "default": "gpt-4o"
    },
    "tools_enabled": {
      "type": "object",
      "properties": {
        "web_search": {
          "type": "boolean",
          "default": false
        },
        "gmail_read": {
          "type": "boolean",
          "default": false
        },
        "gmail_send": {
          "type": "boolean",
          "default": false
        },
        "memory": {
          "type": "boolean",
          "default": true
        }
      },
      "default": {
        "web_search": false,
        "gmail_read": false,
        "gmail_send": false,
        "memory": true
      }
    },
    "color": {
      "type": "string",
      "default": "#4A7FA5"
    }
  },
  "required": [
    "name",
    "system_prompt"
  ]
}