{
  "name": "Agent",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Display name of the agent"
    },
    "role_description": {
      "type": "string",
      "description": "Short description of the agent's role"
    },
    "system_prompt": {
      "type": "string",
      "description": "System prompt that defines the agent's behavior"
    },
    "persona_profile": {
      "type": "string",
      "description": "Auto-generated writing persona profile that defines the agent's tone and style"
    },
    "knowledge_files": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": [],
      "description": "Reference files used to train the agent's tone and knowledge"
    },
    "model": {
      "type": "string",
      "enum": [
        "gpt-5.5",
        "gpt-5.4",
        "gpt-4.1-mini",
        "claude-opus-4-8",
        "claude-sonnet-4-6",
        "claude-haiku-4-5",
        "gemini-3.1-pro",
        "gemini-3.5-flash",
        "gemini-2.5-flash-lite",
        "sonar-pro",
        "sonar-reasoning-pro",
        "sonar-deep-research"
      ],
      "default": "gpt-5.4"
    },
    "tools_enabled": {
      "type": "object",
      "properties": {
        "web_search": {
          "type": "boolean",
          "default": false
        },
        "gmail_read": {
          "type": "boolean",
          "default": false
        },
        "gmail_send": {
          "type": "boolean",
          "default": false
        },
        "drive_read": {
          "type": "boolean",
          "default": false
        },
        "fetch_url": {
          "type": "boolean",
          "default": false
        },
        "memory": {
          "type": "boolean",
          "default": true
        }
      },
      "default": {
        "web_search": false,
        "gmail_read": false,
        "gmail_send": false,
        "drive_read": false,
        "fetch_url": false,
        "memory": true
      }
    },
    "color": {
      "type": "string",
      "default": "#4A7FA5"
    }
  },
  "required": [
    "name",
    "system_prompt"
  ]
}