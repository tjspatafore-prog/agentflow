{
  "name": "SharedKnowledgeBase",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "description": "Title of the knowledge resource"
    },
    "description": {
      "type": "string",
      "description": "Brief description of the content"
    },
    "file_url": {
      "type": "string",
      "description": "URL of the uploaded file in storage"
    },
    "file_type": {
      "type": "string",
      "description": "File extension (e.g. pdf, txt, docx)"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": [],
      "description": "Flexible categorization tags for this resource (e.g. CBT, Trauma, Youth, Marriage)"
    }
  },
  "required": [
    "title",
    "file_url"
  ]
}